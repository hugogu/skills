# Docker Deployment Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# REGISTRY CONFIGURATION
# =============================================================================
# The registry prefix determines where images are pulled from/pushed to
# Local development: localhost:5000
# Docker Hub: docker.io/username or just username
# GitHub Container Registry: ghcr.io/username
# AWS ECR: <account>.dkr.ecr.<region>.amazonaws.com
# GCP GCR: gcr.io/<project-id>
# Azure ACR: <registry>.azurecr.io
# =============================================================================
REGISTRY_PREFIX=localhost:5000

# =============================================================================
# APPLICATION VERSION
# =============================================================================
# Version tag for custom application images
# Should be updated with each release
# =============================================================================
APP_VERSION=1.0.0

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Environment name: local, development, staging, production
# Used to configure service behavior
# =============================================================================
ENV=local

# =============================================================================
# API SERVICE CONFIGURATION
# =============================================================================
# Port mapping for API service
API_PORT=8080

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# PostgreSQL version - ALWAYS use specific version, never 'latest'
# Check https://hub.docker.com/_/postgres for available versions
DB_VERSION=15.4

# Database name
DB_NAME=myapp

# Database user
DB_USER=myappuser

# Database password - CHANGE THIS IN PRODUCTION!
# In production, use secrets management (Docker Swarm secrets, Kubernetes secrets, etc.)
DB_PASSWORD=changeme_in_production

# Database port mapping
DB_PORT=5432

# Database volume path (optional - leave empty for named volume)
DB_DATA_PATH=

# =============================================================================
# CACHE CONFIGURATION (Redis)
# =============================================================================
# Redis version - ALWAYS use specific version
# Check https://hub.docker.com/_/redis for available versions
REDIS_VERSION=7.2.3

# Redis port mapping
REDIS_PORT=6379

# =============================================================================
# MESSAGE QUEUE (Optional - uncomment if using)
# =============================================================================
# RabbitMQ version
# RABBITMQ_VERSION=3.12.6

# RabbitMQ port mappings
# RABBITMQ_PORT=5672
# RABBITMQ_MGMT_PORT=15672

# RabbitMQ credentials
# RABBITMQ_USER=myapp
# RABBITMQ_PASSWORD=changeme_in_production

# =============================================================================
# MONITORING (Optional - uncomment if using)
# =============================================================================
# Prometheus version
# PROMETHEUS_VERSION=2.48.0

# Grafana version
# GRAFANA_VERSION=10.2.3

# Grafana admin password
# GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# NETWORKING
# =============================================================================
# Docker network name
NETWORK_NAME=myapp-network

# =============================================================================
# LOGGING
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log retention in days
LOG_RETENTION_DAYS=7

# =============================================================================
# SECURITY
# =============================================================================
# Enable HTTPS (for reverse proxy configuration)
# ENABLE_HTTPS=false

# SSL certificate path (if ENABLE_HTTPS=true)
# SSL_CERT_PATH=/path/to/cert.pem

# SSL key path (if ENABLE_HTTPS=true)
# SSL_KEY_PATH=/path/to/key.pem

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Enable hot reload for development
DEV_HOT_RELOAD=true

# Debug mode
DEBUG=false

# =============================================================================
# THIRD-PARTY SERVICE VERSIONS
# =============================================================================
# Always pin to specific versions - check Docker Hub for latest
# Format: SERVICE_VERSION=X.Y.Z

# nginx (if using as reverse proxy)
# NGINX_VERSION=1.25.3

# MongoDB (if using instead of PostgreSQL)
# MONGO_VERSION=7.0.4

# Elasticsearch (if using)
# ELASTICSEARCH_VERSION=8.11.1

# =============================================================================
# CUSTOM SERVICE CONFIGURATION
# =============================================================================
# Add your service-specific environment variables here
# Example:
# MY_SERVICE_API_KEY=your_api_key_here
# MY_SERVICE_TIMEOUT=30
