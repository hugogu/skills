# K6 Stress Test Suite - Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Grafana Configuration
# =============================================================================

# Port for Grafana UI (default: 3000)
# Access Grafana at http://localhost:${GRAFANA_PORT}
GRAFANA_PORT=3000

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# InfluxDB Configuration (v1.8)
# =============================================================================

# Port for InfluxDB API (default: 8086)
INFLUXDB_PORT=8086

# InfluxDB database name for k6 metrics
INFLUXDB_DB=k6

# =============================================================================
# k6 Test Configuration
# =============================================================================

# Target URL for tests (default: k6 test site)
# Change this to your API endpoint
TARGET_URL=https://test.k6.io

# Additional k6 options can be passed via environment variables
# K6_VUS=10
# K6_DURATION=30s
